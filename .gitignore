# Secrets & credentials — never commit (see CLAUDE.md)
.env
.env.*
*.pem
*.key
*.p8
*.p12
rsa_key*
.snowsql/
snowsql_config
config/*.local.*
config/secrets.*
credentials.*
*.token

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.env312/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Data — keep generated synthetic data out of git (it's regenerable via the generator)
data/
*.csv
*.parquet
!tests/**/*.csv
!docs/**/*.csv
# ...but keep the tiny committed sample set for repo readability
!sql/10_ingest/samples/
!sql/10_ingest/samples/*.csv

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Logs
logs/
*.log
