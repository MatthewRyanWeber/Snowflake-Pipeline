# Normalize line endings. Shell + SQL run under WSL2/Linux — force LF so a CRLF
# checkout never breaks bash or SnowSQL.
* text=auto

*.sh   text eol=lf
*.sql  text eol=lf
*.conf text eol=lf
*.py   text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf

# Windows-only helpers keep CRLF.
*.bat  text eol=crlf
*.ps1  text eol=crlf
